{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "jdtls": {
      "disabled": true
    }
  },
  "permission": "allow",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["node", "/app/node_modules/@playwright/mcp/cli.js", "--browser", "chrome", "--no-sandbox"],
      "enabled": true
    },
    "rick": {
      "type": "local",
      "command": ["node", "/app/rick-mcp.mjs"],
      "enabled": true
    }
  }
}
