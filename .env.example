# === LLM Providers ===
# Gemini (obrigatorio - modelo principal)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview

# Anthropic (opcional - fallback via API key)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (opcional - fallback via API key)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === Database ===
# PostgreSQL (opcional - Rick usa SQLite quando nao configurado)
DATABASE_URL=postgresql://user:password@localhost:5432/zap_agent
VECTOR_DATABASE_URL=postgresql://user:password@localhost:5432/zap_vectors

# === Web UI ===
# Senha para autenticacao no Web UI (necessario para o Web connector iniciar)
WEB_AUTH_PASSWORD=
# URL publica para links de sessao (sem barra final)
WEB_BASE_URL=https://rick.barroso.tec.br
# Porta do servidor HTTP + WebSocket (padrao: 80)
WEB_PORT=80

# === WhatsApp ===
# ID do dono do bot (sera preenchido automaticamente no primeiro uso)
OWNER_PHONE=

# === Agent ===
AGENT_NAME=Jarvis
AGENT_LANGUAGE=pt-BR
MAX_MEMORY_ITEMS=1000
CONVERSATION_HISTORY_LIMIT=20

# === Security ===
# Chave para criptografia AES-256-GCM de memorias sensiveis
# Se nao configurado, credenciais sao armazenadas em texto plano
MEMORY_ENCRYPTION_KEY=

# === Deploy ===
# Caminho do projeto no host (para modo de edicao)
HOST_PROJECT_DIR=/home/ubuntu/zap-agent

# === Monitoring ===
# Tamanho maximo do vector DB em GB antes de eviction (padrao: 36)
VECTOR_DB_MAX_SIZE_GB=36
# Intervalo de verificacao de disco em minutos (padrao: 10)
DISK_CHECK_INTERVAL_MINUTES=10
# Nivel de log do Pino (padrao: info)
LOG_LEVEL=info
